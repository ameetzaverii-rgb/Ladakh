# .env.example
# Copy to .env.local and fill in values. NEVER commit .env.local

# ─── DATABASE (Neon) ───────────────────────────────
# Get from: https://neon.tech → Your Project → Connection Details
DATABASE_URL="postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/leh-ladakh-guide?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/leh-ladakh-guide?sslmode=require"

# ─── NEXTAUTH ──────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Local dev:
NEXTAUTH_URL="http://localhost:3000"
# On Vercel: set this to your production URL or use VERCEL_URL (auto-set by Vercel)

# ─── ADMIN CREDENTIALS ─────────────────────────────
ADMIN_EMAIL="your@email.com"
# Generate hash: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH="$2a$10$..."

# ─── OPTIONAL: EXTERNAL DATA SOURCES ───────────────
# Skyscanner Rapid API (for live flight prices)
# SKYSCANNER_API_KEY=""
# SKYSCANNER_API_HOST="skyscanner50.p.rapidapi.com"

# Booking.com Affiliate API (for stay availability)
# BOOKING_AFFILIATE_ID=""
# BOOKING_API_KEY=""

# ─── TRIP CONFIG FALLBACKS ─────────────────────────
TRIP_START_DATE="2026-07-22"
TRIP_END_DATE="2026-08-11"
TRIP_BUDGET_INR="150000"
TRAVELER_NAME="Amit"
