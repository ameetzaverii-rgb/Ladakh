// prisma/schema.prisma
// Leh Ladakh Workation Guide — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // Uncomment only if using Neon
}

// ─────────────────────────────────────────
// FLIGHTS
// ─────────────────────────────────────────

model Flight {
  id            String    @id @default(cuid())
  origin        String    // "DEL" | "BOM" | "CCU" etc.
  destination   String    @default("IXL") // Kushok Bakula Airport
  airline       String    // "IndiGo" | "Air India" | "SpiceJet"
  flightNumber  String?
  departureTime String    // "07:30" — local time
  durationMins  Int       // 75 = 1hr 15min
  priceINR      Int       // Economy lowest available
  priceUpdated  DateTime  @default(now())
  available     Boolean   @default(true)
  bookingUrl    String?
  notes         String?   // "Book 6-8 weeks ahead for July"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([origin, available])
}

// ─────────────────────────────────────────
// ACCOMMODATION
// ─────────────────────────────────────────

model Stay {
  id               String      @id @default(cuid())
  name             String      // "The Grand Dragon Ladakh"
  type             StayType    @default(HOTEL)
  neighbourhood    String      // "Fort Road" | "Changspa" | "Old Town"
  pricePerNightINR Int         // Lowest available room
  priceMonthlyINR  Int?        // For long-stay negotiations
  wifiRating       Int         @default(3) // 1-5
  hasCoworking     Boolean     @default(false)
  hasPowerBackup   Boolean     @default(true)
  viewType         String?     // "Stok Kangri range" | "Zanskar valley"
  breakfastIncl    Boolean     @default(false)
  available        Boolean     @default(true)
  bookingUrl       String?
  phone            String?
  description      String      @db.Text
  highlights       String[]    // ["Great WiFi", "Mountain View", "Coworking"]
  priceUpdated     DateTime    @default(now())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([type, available])
}

enum StayType {
  HOTEL
  GUESTHOUSE
  HOSTEL
  HOMESTAY
  APARTMENT
}

// ─────────────────────────────────────────
// TREKS
// ─────────────────────────────────────────

model Trek {
  id             String         @id @default(cuid())
  name           String         // "Sham Valley Trek"
  difficulty     TrekDifficulty @default(MEDIUM)
  durationDays   Int            // 1 or 2
  maxAltitudeM   Int            // metres
  distanceKm     Int?
  startPoint     String         // "Leh" | "Stok Village"
  permitRequired Boolean        @default(false)
  priceINR       Int            // Per person with guide
  company        String?        // "Ju-Leh Adventure" | "Ancient Tracks"
  companyUrl     String?
  nextDeparture  DateTime?
  available      Boolean        @default(true)
  description    String         @db.Text
  highlights     String[]
  season         String         @default("June–September")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum TrekDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

// ─────────────────────────────────────────
// EVENTS & FESTIVALS
// ─────────────────────────────────────────

model Event {
  id             String    @id @default(cuid())
  name           String    // "Phyang Tsedup Festival"
  type           EventType @default(FESTIVAL)
  location       String    // "Phyang Monastery, 17km from Leh"
  startDate      DateTime
  endDate        DateTime
  ticketRequired Boolean   @default(false)
  ticketPriceINR Int?
  ticketUrl      String?
  freeEntry      Boolean   @default(true)
  description    String    @db.Text
  tips           String?   // "Arrive early morning"
  distanceFromLehKm Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([startDate])
}

enum EventType {
  FESTIVAL
  CULTURAL
  MONASTERY
  MARKET
  SPORTS
  ASTRONOMY
}

// ─────────────────────────────────────────
// TRANSPORT
// ─────────────────────────────────────────

model Transport {
  id               String        @id @default(cuid())
  type             TransportType @default(TAXI)
  destination      String        // "Pangong Tso"
  distanceKm       Int?
  rateINR          Int           // One-way or per day
  rateType         String        @default("one-way") // "one-way" | "per-day" | "2-day"
  permitRequired   Boolean       @default(false)
  permitTypes      String[]      // ["ILP", "RAP"]
  permitCostINR    Int?
  durationHours    Float?        // One-way travel time
  notes            String?
  available        Boolean       @default(true)
  contactName      String?       // Recommended driver name
  contactPhone     String?
  rateUpdated      DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum TransportType {
  TAXI
  SHARED_JEEP
  BIKE_RENTAL
  TREKKING_TRANSFER
}

// ─────────────────────────────────────────
// CAFES & RESTAURANTS
// ─────────────────────────────────────────

model Place {
  id            String    @id @default(cuid())
  name          String    // "Lehvenda Café"
  type          PlaceType @default(CAFE)
  neighbourhood String
  description   String    @db.Text
  mustOrder     String[]  // ["Specialty pour-over", "Apricot cake"]
  wifiAvailable Boolean   @default(false)
  laptopFriendly Boolean  @default(false)
  avgBudgetINR  Int?      // Per meal/visit
  openNow       Boolean   @default(true)
  seasonal      Boolean   @default(true) // Most Leh places close Oct–Apr
  phone         String?
  mapsUrl       String?
  tags          String[]  // ["Best Views", "Work-Friendly", "Local Food"]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum PlaceType {
  CAFE
  RESTAURANT
  STREET_FOOD
  BAKERY
  DHABA
}

// ─────────────────────────────────────────
// ITINERARY (21-day plan — editable)
// ─────────────────────────────────────────

model ItineraryDay {
  id              String   @id @default(cuid())
  dayNumber       Int      @unique // 1–21
  dayOfWeek       String   // "Sat" | "Sun" | "Mon" etc.
  title           String   // "🛬 Arrive Leh — Absolute Rest Day"
  description     String   @db.Text
  isWorkDay       Boolean  @default(true)
  isTrekDay       Boolean  @default(false)
  isExcursionDay  Boolean  @default(false)
  isFestivalDay   Boolean  @default(false)
  breakfastNote   String?
  lunchNote       String?
  dinnerNote      String?
  // Personal customisation
  activities      Json     @default("[]") // [{id,text,done}] per-day checklist
  isCustom        Boolean  @default(false) // user-added "extra stop"
  sortOrder       Float?   // ordering; seeded = dayNumber, custom = fractional
  customName      String?  // optional place name for custom days (map/weather)
  customLat       Float?
  customLng       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dayNumber])
}

// ─────────────────────────────────────────
// TRIP CONFIG
// ─────────────────────────────────────────

model TripConfig {
  id             String   @id @default(cuid())
  tripStartDate  DateTime @default(dbgenerated("'2026-07-22'::date"))
  tripEndDate    DateTime @default(dbgenerated("'2026-08-11'::date"))
  totalBudgetINR Int      @default(150000)
  homeCity       String   @default("Delhi")
  travelerName   String   @default("Amit")
  notes          String?  @db.Text
  categoryBudgets Json?   // Per-category budget targets, editable from the Budget page
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─────────────────────────────────────────
// SHOPPING / SOUVENIR REPOSITORY
// ─────────────────────────────────────────
model ShopItem {
  id           String   @id @default(cuid())
  name         String   // "Pashmina shawl"
  area         String   @default("Leh")     // Where to pick it up: Leh, Nubra, Pangong, Sham, Turtuk, General
  category     String   @default("Handicraft") // Textiles, Food, Handicraft, Jewellery, Spiritual, Misc
  estPriceINR  Int?
  whereToBuy   String?  // "Moti Market, Leh" / specific shop
  priority     String   @default("nice")    // must | nice | maybe
  acquired     Boolean  @default(false)
  notes        String?  @db.Text
  photo        String?  @db.Text            // optional data URL / image link
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([area])
  @@index([acquired])
}

// ─────────────────────────────────────────
// PREPARATION CHECKLIST
// ─────────────────────────────────────────

model ChecklistItem {
  id          String            @id @default(cuid())
  title       String
  category    ChecklistCategory @default(MISC)
  phase       ChecklistPhase    @default(MONTH_BEFORE)
  dueDate     DateTime?
  completed   Boolean           @default(false)
  completedAt DateTime?
  notes       String?
  priority    Int               @default(2) // 1=high 2=medium 3=low
  bookingRef  String?
  costINR     Int?
  url         String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum ChecklistCategory {
  FLIGHTS
  ACCOMMODATION
  TRANSPORT
  PERMITS
  GEAR
  HEALTH
  DOCUMENTS
  WORK_SETUP
  MONEY
  MISC
}

enum ChecklistPhase {
  ASAP
  MONTH_BEFORE
  TWO_WEEKS_BEFORE
  WEEK_BEFORE
  DAY_BEFORE
  ON_TRIP
}

// ─────────────────────────────────────────
// TRIP JOURNAL
// ─────────────────────────────────────────

model JournalEntry {
  id         String   @id @default(cuid())
  tripDay    Int
  date       DateTime
  title      String?
  content    String   @db.Text
  mood       Int?     // 1-5
  highlights String[]
  lowlights  String[]
  photos     String[] // URLs
  location   String?
  weather    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tripDay])
  @@index([date])
}

// ─────────────────────────────────────────
// EXPENSE / BUDGET TRACKER
// ─────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  tripDay     Int
  date        DateTime
  amountINR   Int
  category    ExpenseCategory @default(MISC)
  description String
  place       String?
  paymentMode String          @default("cash") // "cash" | "upi" | "card"
  receipt     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tripDay])
  @@index([date])
  @@index([category])
}

enum ExpenseCategory {
  ACCOMMODATION
  FOOD
  TRANSPORT
  TREK
  PERMITS
  SHOPPING
  HEALTH
  WORK
  MISC
}

// ─────────────────────────────────────────
// ADMIN / SESSION (NextAuth)
// ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  ADMIN
  VIEWER
}
